<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Aquilux Payment Gateway</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Inter,Arial,sans-serif}
body{background:#0a0a0a;color:#fff;display:flex;justify-content:center;align-items:center;min-height:100vh;padding:20px}
.card{max-width:560px;width:100%;background:#111;border:1px solid #2a2a2a;border-radius:22px;padding:28px}
img{width:70px;display:block;margin:auto}
h1{text-align:center;margin:18px 0 8px}
p{text-align:center;color:#aaa}
.summary{margin:22px 0;padding:16px;background:#181818;border-radius:14px}
.summary div{display:flex;justify-content:space-between;margin:8px 0}
button{width:100%;padding:15px;border:none;border-radius:12px;margin-top:12px;font-weight:700;cursor:pointer}
.pay{background:#fff;color:#000}
#paymentDoneBox{display:none;margin-top:24px;padding-top:18px;border-top:1px solid #333}
.yes{background:#18b75a;color:#fff}
.no{background:#2a2a2a;color:#fff}
</style>
</head>
<body>

<div class="card">
<img src="https://i.ibb.co/KcK5JqBf/IMG-0068.png">
<h1>Complete Payment</h1>
<p>Choose your preferred UPI app.</p>

<div class="summary">
<div><span>Customer</span><strong id="customerName">-</strong></div>
<div><span>Total</span><strong>₹<span id="totalAmount">0</span></strong></div>
</div>

<button class="pay" onclick="pay('gpay')">Google Pay</button>
<button class="pay" onclick="pay('phonepe')">PhonePe</button>
<button class="pay" onclick="pay('paytm')">Paytm</button>

<div id="paymentDoneBox">
<h2 style="text-align:center;margin-bottom:10px">Payment Completed?</h2>
<p>Did you successfully complete your payment?</p>
<button class="yes" onclick="paymentDone()">Yes, Payment Done</button>
<button class="no" onclick="hidePaymentDone()">Not Yet</button>
</div>
</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/12.0.0/firebase-app.js";
import { getFirestore, collection, addDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/12.0.0/firebase-firestore.js";

const firebaseConfig={
apiKey:"REPLACE_API_KEY",
authDomain:"REPLACE_AUTH_DOMAIN",
projectId:"REPLACE_PROJECT_ID",
storageBucket:"REPLACE_STORAGE_BUCKET",
messagingSenderId:"REPLACE_SENDER_ID",
appId:"REPLACE_APP_ID"
};

const app=initializeApp(firebaseConfig);
const db=getFirestore(app);

const order=JSON.parse(localStorage.getItem("pendingOrder")||"{}");
document.getElementById("customerName").textContent=order.receiverName||"-";
document.getElementById("totalAmount").textContent=order.total||0;

window.pay=function(appName){
 const upi="Yashojhaoffical1982@oksbi";
 const amount=order.total||0;
 const pn=encodeURIComponent("Aquilux");
 const tn=encodeURIComponent("Aquilux Order");
 let url="";
 if(appName==="gpay")url=`gpay://upi/pay?pa=${upi}&pn=${pn}&tn=${tn}&am=${amount}&cu=INR`;
 if(appName==="phonepe")url=`phonepe://pay?pa=${upi}&pn=${pn}&tn=${tn}&am=${amount}&cu=INR`;
 if(appName==="paytm")url=`paytmmp://pay?pa=${upi}&pn=${pn}&tn=${tn}&am=${amount}&cu=INR`;
 localStorage.setItem("paymentStarted","true");
 location.href=url;
};

window.addEventListener("focus",()=>{
 if(localStorage.getItem("paymentStarted")==="true"){
   document.getElementById("paymentDoneBox").style.display="block";
 }
});

window.hidePaymentDone=function(){
 document.getElementById("paymentDoneBox").style.display="none";
};

window.paymentDone=async function(){
 const orderNo="AQ"+Date.now();
 order.orderNumber=orderNo;
 order.paymentStatus="Pending Verification";
 order.orderStatus="Pending";
 order.createdAt=serverTimestamp();
 try{
   await addDoc(collection(db,"orders"),order);
 }catch(e){
   console.error(e);
 }
 localStorage.setItem("lastOrderNumber",orderNo);
 localStorage.removeItem("paymentStarted");
 location.href="payment.html";
};
</script>
</body>
</html>
