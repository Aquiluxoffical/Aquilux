<body>

<div class="card">

<img src="https://i.ibb.co/KcK5JqBf/IMG-0068.png">

<h1>Complete Payment</h1>

<p>
Choose your preferred UPI app.
</p>

<div class="summary">

<h3>Order Summary</h3>

<p id="customerName"></p>

<p>
₹ <span id="totalAmount"></span>
</p>

</div>

<button onclick="pay('gpay')">
Google Pay
</button>

<button onclick="pay('phonepe')">
PhonePe
</button>

<button onclick="pay('paytm')">
Paytm
</button>

<div id="paymentDoneBox" style="display:none;">

<h2>
Payment Completed?
</h2>

<p>
Did you successfully complete your payment?
</p>

<button onclick="paymentDone()">
Yes, Payment Done
</button>

<button onclick="hidePaymentDone()">
Not Yet
</button>

</div>

</div>

</body>
